# PrexorCloud — compose environment.
# Copy to `.env` next to compose.yml and fill in.

# ─── Image pins ───────────────────────────────────────────────────────
# Override to pin a specific tag. Leave commented to track `latest`.
# PREXORCLOUD_CONTROLLER_IMAGE=ghcr.io/prexorjustin/prexorcloud-controller:1.0.0
# PREXORCLOUD_DAEMON_IMAGE=ghcr.io/prexorjustin/prexorcloud-daemon:1.0.0
# PREXORCLOUD_DASHBOARD_IMAGE=ghcr.io/prexorjustin/prexorcloud-dashboard:1.0.0

# ─── Heap sizes ───────────────────────────────────────────────────────
# Controller: scale with cluster size. 1g is fine up to a few hundred
# instances. Bump to 2g–4g for thousands.
PREXORCLOUD_CONTROLLER_HEAP=1g
# Daemon: low — it doesn't host instances, just supervises them.
PREXORCLOUD_DAEMON_HEAP=512m

# ─── Host ports ───────────────────────────────────────────────────────
# Front the HTTP port with a TLS-terminating reverse proxy in production
# (Caddy / nginx). The gRPC port is mTLS-protected; safe to expose direct.
PREXORCLOUD_HTTP_PORT=8080
PREXORCLOUD_GRPC_PORT=9090
PREXORCLOUD_DASHBOARD_PORT=3000

# ─── Secrets ──────────────────────────────────────────────────────────
# These belong in controller.yml (mounted into the container). They are
# listed here so an operator who reaches for `.env` first sees the names
# and a pointer.
#
# - security.jwtSecret           — REQUIRED. 32+ random bytes (base64).
# - security.initialAdminPassword — set on first boot only; clear after.
# - database.uri                  — defaults to mongodb://mongo:27017
