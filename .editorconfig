root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{java,kt,kts}]
indent_size = 4
max_line_length = 120

[*.{js,ts,vue,jsx,tsx,json,yml,yaml,css,scss,html,astro,mjs,cjs}]
indent_size = 2

[*.toml]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.gradle]
indent_size = 4
