# Java / Gradle
**/build/
**/.gradle/
*.class
*.jar
!java/cloud-modules/example/**/src/**/*.jar
!**/gradle/wrapper/gradle-wrapper.jar

# Node / Frontend
node_modules/
**/dist/
**/.nuxt/
**/.output/
*.log

# IDE
.idea/
.vscode/
# ...except the VS Code extension package, whose .vscode/ is project config.
!dashboard/packages/vscode-extension/.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Local config / secrets
.env
*.env
*.env.local
*.local
**/.initial-admin-password
**/logs/

# Secrets and credentials — never tracked
*.pem
*.p12
*.key
*.keystore
*.jks
**/config/security/
.gitleaks-report.json

# Agent / IDE workspace artifacts
.mcp.json
.fleet/
.run/
.cache/

# Stray archives at repo root
/*.zip
/*.tar.gz


# CLI builds — local-only artefacts, never tracked
cli/dist/
cli/prexorctl
cli/prexorctl.exe
cli/prexorctl-*

# Stale binary blobs that used to live in git pre-v1-cleanup (kept here so a
# `git add` of any of these is a no-op). The canonical sources are:
#   - dashboard source under dashboard/app/
#   - design system reference under design-system/
dashboard/app.zip
design-system/*.zip
# design-system/dist/ is a generated-but-committed artifact (token diffs stay
# reviewable in PRs; consumers import it without a build). Re-include it past the
# blanket **/dist/ ignore above. CI proves it stays fresh.
!design-system/dist/
!design-system/dist/**

# Test-harness snapshot artefacts (regenerated by tests; the fixture
# templates under cache/templates/ are tracked deliberately).
java/cloud-test-harness/templates/*/snapshots/*.tar.gz

# Auto-generated synced spec for the Astro dev server (re-emitted by
# website/scripts/sync-openapi.mjs on every dev/build).
website/public/openapi.json

# Local editor / tooling workspace artifacts
.cursor/
.aider*

# Private design handoff — kept on disk for the maintainer; the canonical
# tokens used by the dashboard / installer / website live in those projects.
design_handoff_reef/
