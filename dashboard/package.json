{
  "name": "dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm sdk:check && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "openapi:validate": "redocly lint ../docs/openapi.json",
    "sdk:check": "pnpm openapi:validate && pnpm --filter @prexorcloud/api-sdk check",
    "test": "vitest run",
    "i18n:check": "node i18n/check-locale-parity.mjs",
    "i18n:check-hardcoded": "node i18n/check-hardcoded.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "nuxt typecheck",
    "story": "histoire dev",
    "story:build": "histoire build",
    "story:preview": "histoire preview",
    "lint": "eslint .",
    "lint:voice": "bash scripts/lint-voice.sh",
    "format": "prettier --write \"app/**/*.{ts,tsx,js,vue,css,json}\" \"components/**/*.{ts,tsx,js,vue,css,json}\" \"pages/**/*.{ts,tsx,js,vue,css,json}\" \"layouts/**/*.{ts,tsx,js,vue,css,json}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,js,vue,css,json}\" \"components/**/*.{ts,tsx,js,vue,css,json}\" \"pages/**/*.{ts,tsx,js,vue,css,json}\" \"layouts/**/*.{ts,tsx,js,vue,css,json}\"",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "sdk:generate": "pnpm --filter @prexorcloud/api-sdk generate",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "10.3.0",
    "@pinia/nuxt": "^0.11.3",
    "@prexorcloud/api-sdk": "workspace:*",
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vue-flow/background": "^1.3.0",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.41.0",
    "@vue-flow/minimap": "^1.5.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "diff": "^8.0.4",
    "echarts": "^6.0.0",
    "fuse.js": "^7.1.0",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "vee-validate": "^4.15.1",
    "virtua": "^0.41.0",
    "vue": "^3.5.31",
    "vue-codemirror": "^6.1.1",
    "vue-echarts": "^7.0.3",
    "vue-sonner": "^2.0.9",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@histoire/plugin-vue": "1.0.0-beta.1",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.50.0",
    "@redocly/cli": "^2.28.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/language-core": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.9",
    "histoire": "1.0.0-beta.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
