{
  "name": "@prexorcloud/api-sdk",
  "version": "0.1.0",
  "description": "Type-safe API client for PrexorCloud, generated from OpenAPI spec",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "openapi-typescript ../../../docs/openapi.json -o src/types.d.ts",
    "check": "openapi-typescript ../../../docs/openapi.json -o src/types.d.ts --check",
    "prepare": "openapi-typescript ../../../docs/openapi.json -o src/types.d.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.6.0",
    "typescript": "^5.7.0"
  }
}
