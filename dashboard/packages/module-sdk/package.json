{
  "name": "@prexorcloud/module-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building PrexorCloud dashboard modules",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./src/theme.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src/theme.css"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vue": "^3.5.0"
  }
}
