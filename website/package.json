{
  "name": "prexorcloud-website",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "predev": "node ./scripts/sync-openapi.mjs && node ./scripts/gen-mermaid-theme.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node ./scripts/sync-openapi.mjs && node ./scripts/gen-mermaid-theme.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "gen:mermaid": "node ./scripts/gen-mermaid-theme.mjs",
    "check:links": "node ./scripts/check-links.mjs",
    "gen:cli": "node --experimental-strip-types ../tools/gen-cli-docs.ts",
    "gen:grpc": "../tools/gen-grpc-docs.sh",
    "gen:bench": "node --experimental-strip-types ../tools/gen-benchmarks.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,vue,css,astro,json}\" \"scripts/**/*.{ts,mjs,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,vue,css,astro,json}\" \"scripts/**/*.{ts,mjs,js,json}\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.2.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/starlight": "^0.36.0",
    "@astrojs/starlight-tailwind": "^3.0.1",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vue": "^5.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^5.16.5",
    "lucide-vue-next": "^0.460.0",
    "mermaid": "^11.14.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.4",
    "starlight-openapi": "^0.22.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "unist-util-visit": "^5.1.0"
  }
}
