---
/*
 * <StatusBadge> — colorblind-safe status pill (dot + label, never color
 * alone, per design-system §6 "Color"). The five variants match the
 * dashboard's instance/node state colors so docs and product UI read
 * the same.
 *
 * Usage:
 *   <StatusBadge variant="running" />
 *   <StatusBadge variant="draining">Cordoned</StatusBadge>
 */
const { variant = 'running' } = Astro.props as {
  variant?: 'running' | 'pending' | 'draining' | 'crashed' | 'stopped';
};

const variants = {
  running:  { label: 'Running',  color: 'var(--success)',     filled: true },
  pending:  { label: 'Pending',  color: 'var(--primary)',     filled: true },
  draining: { label: 'Draining', color: 'var(--warning)',     filled: true },
  crashed:  { label: 'Crashed',  color: 'var(--destructive)', filled: true },
  stopped:  { label: 'Stopped',  color: 'var(--muted-foreground)', filled: false },
} as const;

const v = variants[variant];
---

<span class="pc-status" data-variant={variant}>
  <span class={`pc-status-dot ${v.filled ? '' : 'pc-status-dot-hollow'}`} aria-hidden="true"></span>
  <span class="pc-status-label"><slot>{v.label}</slot></span>
</span>

<style define:vars={{ color: v.color }}>
  .pc-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid hsl(var(--color) / 0.35);
    border-radius: var(--radius-full, 9999px);
    background: hsl(var(--color) / 0.12);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium, 500);
    color: hsl(var(--color));
    line-height: 1;
    vertical-align: middle;
  }

  .pc-status-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: hsl(var(--color));
  }

  .pc-status-dot-hollow {
    background: transparent;
    border: 1.5px solid hsl(var(--color));
  }

  .pc-status-label {
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
</style>
