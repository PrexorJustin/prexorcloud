---
/*
 * <Bento> + <BentoCard> — bento-grid layout for "concept overview" pages
 * (e.g. /concepts/architecture/, /reference/module-sdk/). Mirrors the
 * landing-page BentoFeatures component but lives in the docs surface.
 *
 * Usage:
 *   <Bento>
 *     <BentoCard title="Controller" href="/concepts/cluster-model/#controller">
 *       Authoritative state, scheduler, REST API, dashboard host.
 *     </BentoCard>
 *     ...
 *   </Bento>
 *
 * Cards are auto-sized to the grid (`auto-fit, minmax(260px, 1fr)`); on
 * mobile they collapse to a single column. The optional `accent` prop
 * tints the card-corner gradient — see design-system §6 "Cards".
 */
const { columns = 3 } = Astro.props as { columns?: 2 | 3 | 4 };
---

<div class="pc-bento" data-columns={columns}>
  <slot />
</div>

<style define:vars={{ minCol: '260px' }}>
  .pc-bento {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--minCol), 1fr));
    gap: var(--space-5, 1.25rem);
    margin: 1.5rem 0;
  }

  .pc-bento[data-columns='2'] {
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  }
  .pc-bento[data-columns='4'] {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  @media (max-width: 640px) {
    .pc-bento {
      grid-template-columns: 1fr;
    }
  }
</style>
