---
/*
 * Marketing landing — Reef direction.
 *
 * Token-driven (tokens.css). Inter + Inter Tight + Instrument Serif italic
 * (one or two accent words per heading) + JetBrains Mono for real code only.
 * Dual-theme via [data-theme="dark|light"] on <html>.
 *
 * Content rule: nothing on this page is fabricated. Every claim, command,
 * and number maps to something in the repo — README, /docs/public/en/,
 * LICENSE, or the actual CLI. No customer logos, no testimonials, no
 * synthetic stats. The "preview" tile shows real `prexorctl status`
 * output shape (representative, not screenshotted).
 *
 * Endpoint wiring:
 *   - `/getting-started/quickstart/`, `/getting-started/installation/`,
 *     `/reference/cli/`, `/changelog/`, `/blog/` are Starlight doc routes.
 *   - REPO links to the public GitHub repo.
 *   - Install commands point at the static scripts at /install.sh and
 *     /install.ps1 in public/. There is intentionally no /install web
 *     route — the setup wizard is a CLI-only feature (`prexorctl setup`).
 */
import '../styles/tokens.css';
import '../styles/starlight.css';

const VERSION = 'v1.0';
const REPO = 'https://github.com/prexorjustin/prexorcloud';
const title = 'PrexorCloud — Kubernetes for Minecraft';
const description =
  'A self-hosted control plane for Minecraft server fleets. Apache 2.0, mTLS-bootstrapped, cosign-signed modules, yours to run.';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0a10" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Inter+Tight:wght@500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://prexor.cloud" />
    <meta property="og:site_name" content="PrexorCloud" />
    <meta property="og:image" content="https://prexor.cloud/og/default.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://prexor.cloud/og/default.png" />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'SoftwareApplication',
        name: 'PrexorCloud',
        applicationCategory: 'DeveloperApplication',
        operatingSystem: 'Linux, Windows, macOS',
        description: description,
        url: 'https://prexor.cloud',
        license: 'https://www.apache.org/licenses/LICENSE-2.0',
        offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      })}
    />
  </head>

  <body>
    {/* ───────────── Sticky nav ───────────── */}
    <nav class="reef-nav">
      <a href="/" class="brand" aria-label="PrexorCloud home">
        <svg width="22" height="22" viewBox="0 0 22 22" class="brand-mark" aria-hidden="true">
          <g fill="currentColor">
            <rect x="4.4" y="0" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="8.7" y="0" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="0" y="4.3" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="4.4" y="4.3" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="8.7" y="4.3" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="13" y="4.3" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="0" y="8.7" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="4.4" y="8.7" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="8.7" y="8.7" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="13" y="8.7" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="4.4" y="13" width="3.2" height="3.2" rx="0.6"></rect>
            <rect x="8.7" y="13" width="3.2" height="3.2" rx="0.6"></rect>
          </g>
        </svg>
        <span class="brand-name">PrexorCloud</span>
      </a>
      <div class="nav-links">
        <a href="#features">Product</a>
        <a href="/getting-started/what-is-prexorcloud/">Docs</a>
        <a href="/changelog/">Changelog</a>
        <a href="/blog/">Blog</a>
      </div>
      <div class="nav-actions">
        <a href={REPO} rel="external" class="nav-gh" aria-label="GitHub repository">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 .3c-6.6 0-12 5.4-12 12 0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.8-1.6 8.2-6.1 8.2-11.4 0-6.6-5.4-12-12-12Z"
            >
            </path>
          </svg>
          <span>GitHub</span>
        </a>
        <a href="/getting-started/quickstart/" class="btn-mono">Get started</a>
      </div>
    </nav>

    {/* ───────────── Hero ───────────── */}
    <section class="hero">
      <div class="hero-wash" aria-hidden="true"></div>
      <div class="hero-grid">
        <div>
          <a href="/changelog/" class="hero-pill">
            <span class="hero-pill__tag">NEW</span>
            <span>{VERSION} · Production-ready release</span>
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>
          <h1 class="hero-title">
            Kubernetes for <em class="accent-serif">Minecraft,</em><br />
            finally.
          </h1>
          <p class="hero-lede">
            A self-hosted control plane for Minecraft server fleets. mTLS bootstrap from a single
            join token. Cosign-signed modules verified offline against Rekor. Apache 2.0, yours to
            run.
          </p>
          <div class="hero-cta">
            <a href="/getting-started/quickstart/" class="btn-mono">
              Read the docs
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14M13 5l7 7-7 7"></path>
              </svg>
            </a>
            <a href={REPO} class="btn-ghost" rel="external">View on GitHub</a>
          </div>
          <div class="quick-install" aria-label="Quick install">
            <div class="qi-tabs" role="tablist" aria-label="Operating system">
              <button
                class="qi-tab is-active"
                data-target="unix"
                role="tab"
                aria-selected="true"
                type="button"
              >
                macOS · Linux
              </button>
              <button
                class="qi-tab"
                data-target="win"
                role="tab"
                aria-selected="false"
                type="button"
              >
                Windows
              </button>
            </div>
            <div class="qi-card" role="tabpanel">
              <span class="qi-prompt" data-os="unix">$</span>
              <span class="qi-prompt" data-os="win" hidden>PS&gt;</span>
              <code class="qi-cmd">
                <span data-os="unix">
                  curl -fsSL <span class="qi-accent">prexor.cloud/install.sh</span> | sh
                </span>
                <span data-os="win" hidden>
                  irm <span class="qi-accent">prexor.cloud/install.ps1</span> | iex
                </span>
              </code>
              <button class="qi-copy" type="button" aria-label="Copy install command" title="Copy">
                <svg
                  class="qi-copy__icon qi-copy__icon--copy"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="9" y="9" width="13" height="13" rx="2"></rect><path
                    d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                  >
                  </path>
                </svg>
                <svg
                  class="qi-copy__icon qi-copy__icon--ok"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </button>
            </div>
          </div>
        </div>

        {
          /* Right column — a representative `prexorctl status` view.
           Not a screenshot: it shows the actual output shape from the
           CLI's status command. Numbers are illustrative — labelled
           "example output" in the caption. */
        }
        <div class="hero-preview">
          <div class="term term--hero">
            <div class="term-head">
              <span class="dot dot--faint"></span>
              <span class="dot dot--faint"></span>
              <span class="dot dot--faint"></span>
              <span class="term-name">~ · prexorctl status</span>
            </div>
            <pre
              class="term-body"><span class="t-com"># overview · context: default</span>
<span class="t-prompt">$</span> <span class="t-accent">prexorctl status</span>

<span class="t-ok">●</span> controller        <span class="t-com">https://controller.local:8080</span>
<span class="t-ok">●</span> state.store       <span class="t-muted">mongo · available</span>
<span class="t-ok">●</span> coordination      <span class="t-muted">valkey · available</span>

<span class="t-com"># nodes</span>
NAME            STATE     INSTANCES   UPTIME
node-eu-1       <span class="t-ok">ready</span>     <span class="t-mono">7</span>           <span class="t-mono">14d</span>
node-eu-2       <span class="t-ok">ready</span>     <span class="t-mono">5</span>           <span class="t-mono">9d</span>
node-us-1       <span class="t-ok">ready</span>     <span class="t-mono">3</span>           <span class="t-mono">2d</span></pre>
          </div>
          <div class="preview-foot">
            <span class="preview-foot__by">Example output from <code>prexorctl status</code>.</span>
          </div>
        </div>
      </div>
    </section>

    {/* ───────────── Features ───────────── */}
    <section class="band" id="features">
      <div class="container">
        <div class="band-head">
          <h2 class="section-title">
            Three things it does <em class="accent-serif">really well.</em>
          </h2>
          <a href="/getting-started/what-is-prexorcloud/" class="more-link">
            What is PrexorCloud
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
        <div class="feat-grid">
          <div class="feat">
            <div class="eyebrow">Schedule</div>
            <div class="feat-title">Real scheduling.</div>
            <p>
              Place instances on nodes by RAM, region, tags, or any constraint you encode. The
              scheduler is plain Java — read the code, fork it, replace it. No black-box
              bin-packing.
            </p>
          </div>
          <div class="feat">
            <div class="eyebrow">Observe</div>
            <div class="feat-title">Real telemetry.</div>
            <p>
              Crash loops, draining nodes, player-count time-series, p99 latencies. Prometheus
              scrape endpoint when you want it; everything's already streamed live to the dashboard
              over SSE.
            </p>
          </div>
          <div class="feat">
            <div class="eyebrow">Extend</div>
            <div class="feat-title">Signed extension.</div>
            <p>
              Modules are JVM artifacts loaded by the controller. Every release is cosign-signed
              (keyless OIDC) and verified offline against the Rekor transparency log. No vendor SDK
              — the API is REST + gRPC.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ───────────── How it's built ───────────── */}
    <section class="section arch-section">
      <div class="container">
        <div class="arch-head">
          <div class="eyebrow">How it's built</div>
          <h2 class="section-title arch-title">
            Three processes, <em class="accent-serif">one cluster.</em>
          </h2>
          <p class="arch-lede">
            No daemon-of-daemons, no central queue, no required sidecars. A controller, an agent per
            host, and the surfaces operators actually touch.
          </p>
        </div>

        <div class="arch-grid">
          <div class="arch-diagram term">
            <div class="term-head">
              <span class="dot dot--faint"></span>
              <span class="dot dot--faint"></span>
              <span class="dot dot--faint"></span>
              <span class="term-name">topology</span>
            </div>
            <pre
              class="term-body term-body--diagram">                <span class="t-accent">┌──────────────────────┐</span>
                <span class="t-accent">│     Controller       │</span>
                <span class="t-accent">│  REST · gRPC · SSE   │</span>
                <span class="t-accent">│  Scheduler · Events  │</span>
                <span class="t-accent">└──┬───────────┬───────┘</span>
       mTLS / gRPC │           │ JWT / REST + SSE
        ┌──────────┘           └────────────┐
        v                                   v
   <span class="t-accent">┌─────────┐</span>                       <span class="t-accent">┌──────────────┐</span>
   <span class="t-accent">│ Daemon  │</span>  (one per node)      <span class="t-accent">│ Dashboard /  │</span>
   <span class="t-accent">│ Agent   │</span>                       <span class="t-accent">│ prexorctl    │</span>
   <span class="t-accent">└────┬────┘</span>                       <span class="t-accent">└──────────────┘</span>
        │
        v
   <span class="t-muted">Minecraft instances</span></pre>
          </div>

          <ul class="guarantees">
            <li>
              <span class="g-check" aria-hidden="true">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <div>
                <strong>mTLS bootstrap from one join token.</strong>
                Daemons exchange a single-use token for a per-node cert issued by the controller's internal
                CA. Certs rotate without restart.
              </div>
            </li>
            <li>
              <span class="g-check" aria-hidden="true">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <div>
                <strong>Modules signed end-to-end.</strong>
                Cosign keyless (GitHub Actions OIDC) on the artifact; offline Rekor SET enforcement in
                <code>modules.signing.rekor.policy=REQUIRE_SET</code>.
              </div>
            </li>
            <li>
              <span class="g-check" aria-hidden="true">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <div>
                <strong>Nightly DR drill and perf baselines.</strong>
                Backup-restore round-trip runs in CI every night; p99 latencies are CI gates, not dashboards-to-check.
              </div>
            </li>
            <li>
              <span class="g-check" aria-hidden="true">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <div>
                <strong>Apache 2.0, no phone-home.</strong>
                Self-hosted by design. The CLI talks to your controller and nothing else.
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    {/* ───────────── Install ───────────── */}
    <section class="band">
      <div class="container install-grid">
        <div>
          <div class="eyebrow">Install</div>
          <h2 class="section-title">
            One line, then <em class="accent-serif">prexorctl setup.</em>
          </h2>
          <p class="install-lede">
            The installer downloads a single signed binary, verifies its cosign signature + SHA-256,
            and (by default) launches
            <code>prexorctl setup</code> — a browser-based wizard that generates a versioned <code>
              controller.yml
            </code> you commit to your infra repo.
          </p>
          <a href="/getting-started/installation/" class="btn-mono">
            Read the install guide
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M13 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <div class="term">
          <div class="term-head">
            <span class="dot dot--faint"></span>
            <span class="dot dot--faint"></span>
            <span class="dot dot--faint"></span>
            <span class="term-name">~ · install</span>
          </div>
          <pre
            class="term-body"><span class="t-com"># Linux / macOS</span>
<span class="t-prompt">$</span> <span class="t-accent">curl -fsSL prexor.cloud/install.sh | sh</span>

<span class="t-com"># …or Windows (PowerShell)</span>
<span class="t-prompt">PS&gt;</span> <span class="t-accent">irm prexor.cloud/install.ps1 | iex</span>

<span class="t-com"># the wizard answers three questions, then:</span>
<span class="t-ok">✓</span> controller up on :8080
<span class="t-ok">✓</span> daemon up on :9090
<span class="t-ok">✓</span> bootstrap admin password written (one-time)</pre>
        </div>
      </div>
    </section>

    {/* ───────────── Closer ───────────── */}
    <section class="section closer">
      <div class="container">
        <h2 class="closer-title">
          Run it on a <em class="accent-serif">Raspberry Pi.</em><br />
          Run it on a thousand cores.
        </h2>
        <p class="closer-sub">
          One static binary per role. No daemon-of-daemons. The same system whether you're running a
          single closet node or a fleet across data centres — the only thing that changes is how
          many <code>prexorctl token create</code> you've run.
        </p>
        <div class="closer-cta">
          <a href="/getting-started/quickstart/" class="btn-accent">Read the quickstart</a>
          <a href={REPO} class="btn-ghost" rel="external">View on GitHub</a>
        </div>
      </div>
    </section>

    {/* ───────────── Footer ───────────── */}
    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <a href="/" class="footer-brand">
              <svg width="22" height="22" viewBox="0 0 22 22" class="brand-mark" aria-hidden="true">
                <g fill="currentColor">
                  <rect x="4.4" y="0" width="3.2" height="3.2" rx="0.6"></rect><rect
                    x="8.7"
                    y="0"
                    width="3.2"
                    height="3.2"
                    rx="0.6"
                  >
                  </rect><rect x="0" y="4.3" width="3.2" height="3.2" rx="0.6"></rect><rect
                    x="4.4"
                    y="4.3"
                    width="3.2"
                    height="3.2"
                    rx="0.6"
                  >
                  </rect><rect x="8.7" y="4.3" width="3.2" height="3.2" rx="0.6"></rect><rect
                    x="13"
                    y="4.3"
                    width="3.2"
                    height="3.2"
                    rx="0.6"
                  >
                  </rect><rect x="0" y="8.7" width="3.2" height="3.2" rx="0.6"></rect><rect
                    x="4.4"
                    y="8.7"
                    width="3.2"
                    height="3.2"
                    rx="0.6"
                  >
                  </rect><rect x="8.7" y="8.7" width="3.2" height="3.2" rx="0.6"></rect><rect
                    x="13"
                    y="8.7"
                    width="3.2"
                    height="3.2"
                    rx="0.6"
                  >
                  </rect><rect x="4.4" y="13" width="3.2" height="3.2" rx="0.6"></rect><rect
