    <script>
      // Quick-install: OS tabs + copy button. No framework — vanilla, scoped
      // to .quick-install instances. Auto-detects Windows on first load.
      document.querySelectorAll<HTMLElement>('.quick-install').forEach((root) => {
        const tabs = root.querySelectorAll<HTMLButtonElement>('.qi-tab');
        const targets = root.querySelectorAll<HTMLElement>('[data-os]');
        const copyBtn = root.querySelector<HTMLButtonElement>('.qi-copy');

        function setOS(os: string) {
          tabs.forEach((t) => {
            const active = t.dataset.target === os;
            t.classList.toggle('is-active', active);
            t.setAttribute('aria-selected', String(active));
          });
          targets.forEach((el) => {
            el.hidden = el.dataset.os !== os;
          });
        }

        tabs.forEach((t) => {
          t.addEventListener('click', () => {
            if (t.dataset.target) setOS(t.dataset.target);
          });
        });

        // Default to Windows tab on Windows browsers.
        if (/windows/i.test(navigator.userAgent)) setOS('win');

        copyBtn?.addEventListener('click', async () => {
          const visible = root.querySelector<HTMLElement>('.qi-cmd > [data-os]:not([hidden])');
          if (!visible) return;
          try {
            await navigator.clipboard.writeText((visible.textContent ?? '').trim());
            copyBtn.classList.add('is-copied');
            setTimeout(() => copyBtn.classList.remove('is-copied'), 1500);
          } catch {
            // Clipboard API requires a secure context — silently noop on http://
          }
        });
      });
    </script>
