{
  "name": "prexorcloud-installer",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "a11y:check": "node scripts/a11y-lint.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,vue,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,vue,css,html,json}\""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/language-core": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^7.1.0",
    "vite-plugin-singlefile": "^2.2.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
